{
    "name": "@dantenl/umejs",
    "version": "1.1.0",
    "description": "Untitled Markdown Engine",
    "keywords": [
        "markdown",
        "engine",
        "parser",
        "express",
        "static-site",
        "gray-matter",
        "marked"
    ],
    "homepage": "https://github.com/dante-nl/umejs#readme",
    "bugs": {
        "url": "https://github.com/dante-nl/umejs/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dante-nl/umejs.git"
    },
    "license": "GPL-3.0",
    "author": "dante_nl",
    "type": "commonjs",
    "main": "index.js",
    "directories": {
        "lib": "lib"
    },
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write .",
        "build": "node esbuild.config.mjs",
        "test": "node --test",
        "test:esm": "node --test ./tests/esm-verify.test.mjs "
    },
    "files": [
        "index.js",
        "lib/"
    ],
    "engines": {
        "node": ">=22.13 <27.0.0"
    },
    "dependencies": {
        "gray-matter": "^4.0.3",
        "marked": "^18.0.5"
    },
    "peerDependencies": {
        "express": ">=5.0.0"
    },
    "exports": {
        "node": {
            "module-sync": "./dist/esm/index.mjs",
            "default": "./index.js"
        },
        "default": "./dist/esm/index.mjs"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "esbuild": "^0.28.1",
        "eslint": "^10.6.0",
        "globals": "^17.7.0",
        "prettier": "^3.9.4"
    },
    "publishConfig": {
        "access": "public"
    },
    "types": "./index.js",
    "allowScripts": {
        "esbuild@0.28.1": true
    }
}
